# Broker APIs
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# LLM APIs
ANTHROPIC_API_KEY=your_anthropic_api_key
GROQ_API_KEY=your_groq_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# SEC EDGAR (required — use your real name and email)
SEC_EDGAR_USER_AGENT=YourName your@email.com

# Database (Neon PostgreSQL — use the POOLED connection string)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Risk Limits
MAX_POSITION_PCT=0.08
MAX_PORTFOLIO_RISK=0.25

# Dual-track position limits
FUNDAMENTAL_MAX_POSITION_PCT=0.08
MOMENTUM_MAX_POSITION_PCT=0.04
MOMENTUM_MAX_HOLDING_DAYS=10

# Logging
LOG_LEVEL=INFO

# Evolution schedule (cron format — midnight ET daily)
EVOLUTION_SCHEDULE=0 0 * * *

# Notifications (optional — any combination)
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_TRADES=
DISCORD_WEBHOOK_ANALYSIS=
DISCORD_WEBHOOK_STRATEGY=
DISCORD_WEBHOOK_DAILY=
DISCORD_WEBHOOK_SENTIMENT=
DISCORD_WEBHOOK_SYSTEM=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Data sources (optional — missing = skip silently)
FINNHUB_API_KEY=
DUNE_API_KEY=
DUNE_QUERY_ACTIVE_ADDRESSES=0
DUNE_QUERY_EXCHANGE_FLOWS=0
DUNE_QUERY_WHALE_TRANSACTIONS=0

# Dashboard (optional)
DASHBOARD_PORT=8000
DASHBOARD_HOST=127.0.0.1
