{
    "id": "strategy_011",
    "name": "Loose_Pipeline_Test",
    "version": 2,
    "created_by": "manual",
    "description": "Relaxed entry conditions to force full pipeline in paper mode, bypasses consensus gate and signal threshold",
    "asset_class": "stocks",
    "universe": "all_stocks",
    "tier": "sector",
    "bypass_consensus": true,
    "signal_threshold_override": 0.10,

    "fundamental_filters": {
        "pe_ratio_max": 60,
        "revenue_growth_min": -0.05,
        "fcf_margin_min": 0.0,
        "debt_to_equity_max": 3.0,
        "dcf_upside_min": -0.10
    },

    "entry_conditions": {
        "operator": "AND",
        "signals": [
            {"indicator": "rsi", "condition": "below", "threshold": 50, "period": 14},
            {"indicator": "bollinger_bands", "condition": "price_below_upper", "lookback": 20, "std_dev": 2.0}
        ]
    },

    "exit_conditions": {
        "take_profit": {"indicator": "bollinger_bands", "condition": "price_above_upper"},
        "stop_loss": {"type": "fixed_pct", "pct": 0.08},
        "time_exit": {"max_holding_days": 14}
    },

    "position_sizing": {
        "method": "fixed_pct",
        "max_position_pct": 0.03
    },

    "metadata": {
        "status": "testing",
        "generation": 0,
        "paper_trade_days": 0
    }
}
