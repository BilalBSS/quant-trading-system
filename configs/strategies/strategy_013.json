        "stop_loss": {"type": "fixed_pct", "pct": 0.06},
        "time_exit": {"max_holding_days": 14}
    },

    "position_sizing": {
        "method": "fixed_pct",
        "max_position_pct": 0.06
    },

    "metadata": {
        "status": "paper_trading",
        "generation": 1
    },

    "bear_market_overrides": {
        "fundamental_filters": {
            "pe_ratio_max": 65,
            "revenue_growth_min": -0.10,
            "dcf_upside_min": -0.10
        }
